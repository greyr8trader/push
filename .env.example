# Copy this file to .env locally (don't commit .env to git).
# In Railway, set these same vars in the service's Variables tab.

# gRPC endpoint. Demo: grpc-broker-api-demo.match-trader.com:443
# Confirm prod host with your Match-Trader rep before going live.
MT_GRPC_HOST=grpc-broker-api-demo.match-trader.com:443
MT_GRPC_USE_TLS=true

# From Match-Trader CRM admin panel
MT_SYSTEM_UUID=
MT_AUTH_TOKEN=

# Comma-separated logins to watch, no spaces
MT_WATCHLIST_LOGINS=333376259,1005

# n8n webhook that will receive position-opened events
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/mt-position-opened
N8N_WEBHOOK_TOKEN=

# How often to log "stream alive" lines (seconds)
PING_LOG_EVERY_S=300
